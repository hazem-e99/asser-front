PORT=5000
# من Atlas: Connect → Drivers — استبدل <db_password>
MONGODB_URI=mongodb+srv://USER:PASS@cluster.xxx.mongodb.net/?appName=APP

# اختياري: خوادم DNS لفشل SRV محلياً (مفصولة بفواصل)
# MONGO_DNS_SERVERS=8.8.8.8,8.8.4.4,1.1.1.1
JWT_SECRET=change-this-to-a-long-random-string
# فرونت واحد أو أكثر مفصولين بفاصلة (بدون مسافات إضافية بعد الفاصلة إن أمكن)
# مثال إنتاج: CLIENT_ORIGIN=https://asser-tours.vercel.app,https://your-domain.com
CLIENT_ORIGIN=http://localhost:5173

# يُستخدم عند npm run seed فقط عندما لا يوجد أي مستخدم في القاعدة
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
